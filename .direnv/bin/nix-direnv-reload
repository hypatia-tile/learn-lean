#!/usr/bin/env bash
set -e
if [[ ! -d "/Users/kazukishinohara/ghqrepo/github.com/hypatia-tile/learn-lean" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/Users/kazukishinohara/ghqrepo/github.com/hypatia-tile/learn-lean")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/Users/kazukishinohara/ghqrepo/github.com/hypatia-tile/learn-lean" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/Users/kazukishinohara/ghqrepo/github.com/hypatia-tile/learn-lean/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/Users/kazukishinohara/ghqrepo/github.com/hypatia-tile/learn-lean/.envrc" "/Users/kazukishinohara/ghqrepo/github.com/hypatia-tile/learn-lean/.direnv"/*.rc
